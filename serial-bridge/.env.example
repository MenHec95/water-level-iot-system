# Configuración del puerto serial del Arduino
# Windows: COM3, COM4, etc.
# Linux: /dev/ttyUSB0, /dev/ttyACM0
# Mac: /dev/cu.usbmodem14101, /dev/cu.usbserial-*
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=9600

# URL del backend NestJS
# En desarrollo local:
BACKEND_URL=http://localhost:3000
# En producción (Railway/Render):
# BACKEND_URL=https://tu-backend.railway.app

# Modo de comunicación: 'http' o 'websocket'
COMMUNICATION_MODE=http

# Configuración de reconexión
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=3

# Debug mode (muestra más información en consola)
DEBUG=False