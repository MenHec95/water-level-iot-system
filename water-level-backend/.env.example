# App
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/water_level_db?schema=public"

# Security
SIMULATOR_API_KEY=your-secret-key-here

# IoT
SAVE_INTERVAL_SECONDS=30
```

