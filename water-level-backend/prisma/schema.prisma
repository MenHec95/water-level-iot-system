generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Reading {
  id              Int      @id @default(autoincrement())
  level           Int
  mode            Int
  alert           Boolean
  calib           Boolean
  uptime          Int
  savedAt         DateTime @default(now())
  serverTimestamp DateTime

  @@index([savedAt])
  @@index([alert])
  @@map("readings")
}